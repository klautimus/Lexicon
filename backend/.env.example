# Server
PORT=8787
DB_PATH=./data/lexicon.db
MEDIA_ROOTS=C:/Users/kevin/Music

# DeepSeek LLM
DEEPSEEK_API_KEY=sk-replace-me
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING=medium
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Spotify (PKCE — no secret needed)
SPOTIFY_CLIENT_ID=
# Required for spotDL fallback (avoids the shared rate limit). PKCE auth still works without it.
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8787/api/spotify/callback
SPOTIFY_FRONTEND_URL=http://localhost:5173

# SpotiFLAC (downloads tracks/albums/playlists from a Spotify URL into your library)
SPOTIFLAC_BIN=
SPOTIFLAC_OUTPUT=
SPOTIFLAC_FOLDER_FORMAT={artist}/{album}

# spotDL fallback (used when SpotiFLAC can't find the song)
SPOTDL_BIN=
SPOTDL_FORMAT=mp3
SPOTDL_AUDIO_PROVIDERS=piped,youtube,soundcloud,bandcamp

# yt-dlp fallback (used when spotDL is rate-limited; searches YouTube directly — no Spotify)
YTDLP_BIN=
YTDLP_FORMAT=mp3
FFMPEG_BIN=
FFPROBE_BIN=  # Auto-detected from FFMPEG_BIN if empty (replaces ffmpeg.exe with ffprobe.exe)

# Download validation
DOWNLOAD_CONCURRENCY=2

# Podcast downloader (poddl — https://github.com/freshe/poddl)
# Bundled with the installer; set automatically. Override if needed.
PODDL_BIN=
PODCAST_DIR=./podcasts
